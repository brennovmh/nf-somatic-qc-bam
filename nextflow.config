manifest {
    name            = 'qc-secundario'
    author          = 'OpenAI Codex'
    homePage        = 'https://example.org/qc-secundario'
    description     = 'Pipeline Nextflow DSL2 para QC tecnico de analise secundaria em NGS somatico por painel alvo'
    mainScript      = 'main.nf'
    version         = '1.0.0'
    nextflowVersion = '>=24.04.0'
}

params {
    input_dir                           = null
    bed                                 = null
    outdir                              = "${projectDir}/results"
    sample_pattern                      = '^(.*)\\.bam$'
    container_image                     = 'qc-secundario:1.0.0'
    python_executable                  = System.getenv('PYTHON_EXECUTABLE') ?: (new File("${System.getenv('HOME')}/miniconda3/bin/python3").exists() ? "${System.getenv('HOME')}/miniconda3/bin/python3" : (System.getenv('CONDA_PREFIX') ? "${System.getenv('CONDA_PREFIX')}/bin/python3" : 'python3'))

    min_mapped_reads_pct                = 95.0
    max_duplication_rate                = 0.70
    min_target_mean_coverage            = 500.0
    min_pct_target_100x                 = 95.0
    min_pct_target_200x                 = 90.0
    max_critical_genes_below_threshold  = 3
    min_variant_pass_fraction           = 0.50
    min_variant_dp                      = 100
    min_variant_vaf                     = 0.02
    max_weak_variant_fraction           = 0.30
    gene_primary_threshold              = 100
    min_gene_pct_primary                = 90.0
    interval_primary_threshold          = 100
    min_interval_pct_primary            = 90.0
    strand_bias_alert_threshold         = 60.0
    warning_tolerance_fraction          = 0.10
    samtools_threads                    = 16
    samtools_stats_threads              = 8
    enable_tumor_purity                = true
    tumor_purity_min_dp                = 200
    tumor_purity_min_vaf               = 0.05
    tumor_purity_max_vaf               = 0.45
    tumor_purity_min_variants          = 3
    tumor_purity_bin_width             = 0.02
}

process {
    executor = 'local'
    cache = 'lenient'
    cpus = 2
    memory = '4 GB'
    time = '4h'
    shell = ['/bin/bash', '-euo', 'pipefail']
    errorStrategy = 'retry'
    maxRetries = 2
    stageInMode = 'copy'
    stageOutMode = 'copy'

    withName:VALIDATE_INPUTS {
        cpus = 1
        memory = '1 GB'
    }

    withName:NORMALIZE_BED {
        cpus = 1
        memory = '1 GB'
    }

    withName:SAMTOOLS_FLAGSTAT {
        cpus = params.samtools_threads
        memory = '2 GB'
    }

    withName:SAMTOOLS_STATS {
        cpus = params.samtools_stats_threads
        memory = '4 GB'
    }

    withName:SAMTOOLS_TARGET_DEPTH {
        cpus = params.samtools_threads
        memory = '6 GB'
    }

    withName:ESTIMATE_TUMOR_PURITY {
        cpus = 1
        memory = '2 GB'
    }

    withName:RENDER_REPORT {
        cpus = 2
        memory = '6 GB'
        time = '6h'
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/logs/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/logs/execution_report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/logs/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/logs/pipeline_dag.html"
}

includeConfig 'conf/base.config'

profiles {
    standard {
        includeConfig 'conf/standard.config'
    }

    docker {
        includeConfig 'conf/docker.config'
    }

    conda {
        includeConfig 'conf/conda.config'
    }
}
